{
  "name": "islamic-quiz-bot",
  "version": "1.0.0",
  "description": "بوت مسابقات إسلامي احترافي لديسكورد",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "tsx src/database/seed.ts",
    "register": "tsx src/commands/register.ts",
    "import": "tsx scripts/bulk-import.ts",
    "test": "tsx tests/scoring.test.ts",
    "test:scoring": "tsx tests/scoring.test.ts",
    "test:validate": "tsx -e \"const h=require('./src/database/helpers');const u=require('./src/database/users');console.log('Modules loaded successfully')\""
  },
  "dependencies": {
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.7",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
